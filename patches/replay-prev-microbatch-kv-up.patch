+def _format_batch_fingerprint_line(label, current_iteration, current_microbatch, batch):
+    """Use a compact batch fingerprint to prove replayed data identity."""
+    tokens = batch.get("tokens")
+    labels = batch.get("labels")
+
+    tokens_sum = None
+    tokens_head = []
+    if torch.is_tensor(tokens) and tokens is not None:
+        tokens_cpu = tokens.detach().view(-1).to(dtype=torch.int64, device="cpu")
+        tokens_sum = int(tokens_cpu.sum().item())
+        tokens_head = tokens_cpu[:8].tolist()
+
+    labels_sum = None
+    if torch.is_tensor(labels) and labels is not None:
+        labels_sum = int(labels.detach().view(-1).to(dtype=torch.int64).sum().item())
+
+    return (
+        f"[debug-replay-batch] rank={_DEBUG_NORM_RANK} iteration={current_iteration} "
+        f"microbatch={current_microbatch} label={label} "
+        f"tokens_sum={tokens_sum} labels_sum={labels_sum} tokens_head={tokens_head}"
+    )
+
