+def _clone_batch_for_replay(batch):
+    """Clone a batch dict so it can be replayed without aliasing tensors."""
+    cloned_batch = {}
+    for key, value in batch.items():
+        if torch.is_tensor(value):
+            cloned_batch[key] = value.clone()
+        else:
+            cloned_batch[key] = copy.deepcopy(value)
+    return cloned_batch
+
+
+def _parse_iteration_microbatch_pairs(raw_pairs):
+    """Parse 1-based iteration:microbatch CLI selectors."""
+    parsed_pairs = set()
+    for raw_pair in raw_pairs or []:
+        try:
+            iteration_str, microbatch_str = raw_pair.split(":", maxsplit=1)
+            iteration = int(iteration_str)
+            microbatch = int(microbatch_str)
+        except ValueError as exc:
+            raise ValueError(
+                f"Invalid --replay-prev-microbatch value '{raw_pair}'. Expected ITERATION:MICROBATCH."
+            ) from exc
+        if iteration < 1 or microbatch < 1:
+            raise ValueError(
+                f"Invalid --replay-prev-microbatch value '{raw_pair}'. ITERATION and MICROBATCH must both be >= 1."
+            )
+        parsed_pairs.add((iteration, microbatch))
+    return parsed_pairs
+
+
+def _get_replay_prev_microbatch_targets(args):
+    if not hasattr(args, "replay_prev_microbatch_targets"):
+        args.replay_prev_microbatch_targets = _parse_iteration_microbatch_pairs(
+            getattr(args, "replay_prev_microbatch", [])
