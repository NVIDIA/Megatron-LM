+def _register_replay_debug_hooks(model, iteration):
+    """Register a temporary backward hook for layer0 kv_up_proj on rank 34."""
+    if (
+        iteration + 1 != _REPLAY_DEBUG_ITERATION
+        or not torch.distributed.is_available()
+        or not torch.distributed.is_initialized()
+        or torch.distributed.get_rank() != _REPLAY_DEBUG_RANK
+    ):
+        return []
+
+
+    handles = []
+    for model_chunk in model:
+        unwrapped_model_chunk = unwrap_model(model_chunk)
+        named_modules = dict(unwrapped_model_chunk.named_modules())
+        target_module = named_modules.get(_REPLAY_DEBUG_MODULE_SUFFIX)
+        if target_module is None:
+            continue
+
+        try:
+            target_layer = get_attr_wrapped_model(
+                unwrapped_model_chunk, "decoder", allow_none=False, return_model_obj=True
+            ).decoder.layers[0]
+        except RuntimeError:
+            continue
+
+        # Track forward-order microbatch ids so backward lines can be matched
+        # back to the same microbatch.
+        forward_microbatch_ids = []
+
+        def _forward_pre_hook(_, __):
+            current_microbatch = getattr(target_layer, "current_microbatch", None)
+            if current_microbatch is not None:
+                forward_microbatch_ids.append(current_microbatch + 1)
+
+        def _backward_hook(module, grad_input, grad_output):
+            del module, grad_input
+            grad_tensor = next(
+                (grad for grad in grad_output if torch.is_tensor(grad) and grad is not None),
+                None,
+            )
+            if grad_tensor is None:
+                return
+
+            current_microbatch = (
+                forward_microbatch_ids.pop(0) if forward_microbatch_ids else "unknown"
+            )
+            args = get_args()
+            if not hasattr(args, "replay_prev_microbatch_debug_lines"):
+                args.replay_prev_microbatch_debug_lines = []
+            args.replay_prev_microbatch_debug_lines.append(
+                "[debug-kv-up-proj-grad] "
+                f"rank={_REPLAY_DEBUG_RANK} iteration={iteration + 1} "
+                f"microbatch={current_microbatch} label=used "
+                f"module={_REPLAY_DEBUG_MODULE_LABEL} "
+                f"grad_output_l2_norm={_tensor_l2_norm(grad_tensor):.6f}"
+            )
+
+        handles.append(target_module.register_forward_pre_hook(_forward_pre_hook))
+        handles.append(target_module.register_full_backward_hook(_backward_hook))
+
+    return handles
+
+
+def _remove_replay_debug_hooks(handles):
+    """Remove temporary replay debug hooks."""
+    for handle in handles:
+        handle.remove()
+
+
+def _broadcast_replay_debug_lines(args, iteration):
+    """Send rank34 replay debug lines to the rank that prints the main log."""
